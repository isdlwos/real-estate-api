# ─── Général ─────────────────────────────────────────────────────────────────
NODE_ENV=production         # development | production
PORT=3000

# ─── Base de données ─────────────────────────────────────────────────────────
DB_HOST=postgres            # Nom du service Docker en prod, 'localhost' en dev
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME       # Générer : openssl rand -base64 24
DB_DATABASE=real_estate
DB_SYNCHRONIZE=false        # Toujours false en production — utiliser migration:run
DB_LOGGING=false            # Passer à true temporairement pour déboguer

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME         # Générer : openssl rand -base64 32
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME        # Générer : openssl rand -base64 32
JWT_REFRESH_EXPIRES_IN=7d

# ─── Upload fichiers ─────────────────────────────────────────────────────────
UPLOAD_DEST=./uploads/properties
MAX_FILE_SIZE=5242880               # 5 Mo en octets
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp

# ─── CORS ────────────────────────────────────────────────────────────────────
# Séparer plusieurs domaines par une virgule
CORS_ORIGINS=https://votre-domaine.com,https://www.votre-domaine.com
