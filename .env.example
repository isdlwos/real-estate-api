NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_DATABASE=real_estate
DB_SYNCHRONIZE=false
DB_LOGGING=true

